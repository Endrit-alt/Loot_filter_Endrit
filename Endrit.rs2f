/*@ define:input:boss_pvm
label: Enable Sound on Perfect Kill
type: boolean
group: Vardorvis
*/
#define ENABLE_VARDORVIS_PERFECT true

/*@ define:input:boss_pvm
label: Sound ID
type: number
group: Vardorvis
*/
#define VARDORVIS_PERFECT_SOUND 3018

#define VARDORVIS_PERFECT_ITEMS name:"Coal" && quantity:==195) || (name:"Adamantite ore" && quantity:==67) || (name:"Rune javelin tips" && quantity:==54) || (name:"Dragon javelin tips" && quantity:==54) || (name:"Uncut ruby" && quantity:==37) || (name:"Uncut diamond" && quantity:==37) || (name:"Runite ore" && quantity:==27) || (name:"Dragon dart tip" && quantity:==150) || (name:"Pure essence" && quantity:==180) || (name:"Iron ore" && quantity:==57) || (name:"Silver ore" && quantity:==57) || (name:"Mithril ore" && quantity:==57) || (name:"Sapphire" && quantity:==25) || (name:"Emerald" && quantity:==25) || (name:"Ruby" && quantity:==25) || (name:"Raw shark" && quantity:==300) || (name:"Lava rune" && quantity:==300) || (name:"Blood rune" && quantity:==300) || (name:"Soul rune" && quantity:==600) || (name:"Bronze javelin" && quantity:==63) || (name:"Mithril javelin" && quantity:==63) || (name:"Adamant javelin" && quantity:==63) || (name:"Onyx bolts (e)" && quantity:==90) || (name:"Mind rune" && quantity:==180) || (name:"Fire rune" && quantity:==180

AREA_UNHIDE(area:[1114,3407,0,1142,3434,0] && ENABLE_VARDORVIS_PERFECT && ((VARDORVIS_PERFECT_ITEMS)))

apply (area:[1114,3407,0,1142,3434,0] && ENABLE_VARDORVIS_PERFECT && ((VARDORVIS_PERFECT_ITEMS))) {sound=VARDORVIS_PERFECT_SOUND;}

