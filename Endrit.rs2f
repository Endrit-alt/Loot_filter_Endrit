#define SPECIAL_UNIQUE_CHECK(_enabled, _area, _name) 	rule (_enabled && (_area) && name:_name && name:UNQIQUE_SPECIAL_SS_NAMES && ownership:1) {UNIQUE_SS_STYLE} 	rule (_enabled && (_area) && name:_name && name:UNQIQUE_SPECIAL_S_NAMES && ownership:1) {UNIQUE_S_STYLE} 	rule (_enabled && (_area) && name:_name && name:UNQIQUE_SPECIAL_A_NAMES && ownership:1) {UNIQUE_A_STYLE} 	rule (_enabled && (_area) && name:_name && name:UNQIQUE_SPECIAL_B_NAMES && ownership:1) {UNIQUE_B_STYLE} 	rule (_enabled && (_area) && name:_name && name:UNQIQUE_SPECIAL_C_NAMES && ownership:1) {UNIQUE_C_STYLE}

