/*@ define:module:header
hidden: true
name: header
*/

meta { name = "Endrit"; description = "Endrit's Ironman Filter"; }





/*@ define:module:greetings
name: Welcome to Endrit's Iron Filter
description:
    This is filter made for Ironman players. Sit back, relax, and turn off item value. Items are organized into different tiers base on value to ironman, rather than GE price. 
*/





/*@ define:module:settings
name: Settings
subtitle: Basic Global Settings 
*/

/*@ define:input:settings
label: World Spawns
type: boolean
group: Show
*/
#define SHOW_GLOBAL_DROPS true

apply (!SHOW_GLOBAL_DROPS && ownership:0) {hidden = true;}

/*@ define:input:settings
label: Unowned Drops
type: boolean
group: Show
*/
#define SHOW_OTHER_DROPS false

apply (!SHOW_OTHER_DROPS && ownership:2) {hidden = true;}

#define FORCE_SHOW_RULESET(_area, _name) rule (area:_area && name:_name && (!ownership:2 || SHOW_OTHER_DROPS)) {hidden = false;}

/*@ define:input:settings
label: Despawn Timer
type: boolean
group: Show
*/
#define SHOW_DEPSAWN_TIMER true

apply (SHOW_DEPSAWN_TIMER) {showDespawn = true;}

/*@ define:input:settings
label: Item Value
type: boolean
group: Show
*/
#define SHOW_ITEM_VALUE false

apply (SHOW_ITEM_VALUE) {showValue = true;}

/*@ define:input:settings
label: Item Icon
type: boolean
group: Show
*/
#define SHOW_ITEM_ICON false

apply (SHOW_ITEM_ICON) {icon = CurrentItem();}

/*@ define:input:settings
label: UIM Death Piles (Turns off filter) 
type: boolean
group: Show
*/
#define ENABLE_UIM_DEATH_PILES false





