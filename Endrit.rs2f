ead","Feather","Iron dagger","Needle","Damaged armour","Ham cloak","Ham hood","Ham boots","Grimy marrentiill","Steel dagger","Grimy tarromin","Marrentill seed","Bark","Rune dagger","Adamant platelegs","Rune javelin","Rune arrow","Nature rune","Blood pint","Uncut ruby","Jangerberry seed","Steel bar","Black sq shield","Air rune","Adamant longsword","Water rune","Law rune","Adamant battleaxe","Fire rune","Soul rune","Araxyte venom sack","Chaos rune","Death rune","Gold ore","Harralander seed","Earth rune","Strawberry seed","Grimy kwuarm","Rune med helm","Belladonna seed","Avantoe seed","Cosmic rune","Irit seed","Grimy harralander","Limpwurt seed","Wildblood seed","Tarromin seed","Empty plant pot","Iron pickaxe","Big bones","Cave worms","Cave worms"]

apply (name:HIDE_USER) {hidden=true;}

/*@ define:input:hidden
label: Hide if Unnoted
type: stringlist
group: User
*/
#define HIDE_USER_UNNOTED ["Green dragonhide","Blue dragonhide","Red dragonhide","Black dragonhide"]

apply (name:HIDE_USER_UNNOTED && stackable:false)  {hidden=true;}

/*@ define:input:hidden
label: Hide if quant < 10
type: stringlist
group: User
*/
#define HIDE_USER_UNDER_10 []

apply (name:HIDE_USER_UNDER_10 && quantity:<10) {hidden=true;}

/*@ define:input:hidden
label: Hide if quant < 100
type: stringlist
group: User
*/
