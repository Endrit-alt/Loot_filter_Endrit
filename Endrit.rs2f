apply (name:HIDE_USER_UNDER_10000 && quantity:<10000) {hidden=true;}

/*@ define:input:hidden
label: Hide "Fake" Items
type: boolean
group: User
*/
#define ENABLE_HIDE_FAKE true

apply (ENABLE_HIDE_FAKE && id:[2513,4178,4180,6967,21060,31252]) {hidden=true;}

